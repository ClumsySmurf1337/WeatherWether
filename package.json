{
  "name": "weatherwether-tooling",
  "private": true,
  "version": "0.1.0",
  "description": "Tooling and automation scripts for Weather Whether",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "daily:full": "pwsh -NoProfile -File tools/tasks/daily-full.ps1",
    "daily:full:apply": "pwsh -NoProfile -File tools/tasks/daily-full.ps1 -ApplyProducer",
    "daily:full:lanes": "pwsh -NoProfile -File tools/tasks/daily-full.ps1 -EditorLaneTerminals",
    "daily:full:lean": "pwsh -NoProfile -File tools/tasks/daily-full.ps1 -SkipEditorLanePrep",
    "daily:full:apply:lanes": "pwsh -NoProfile -File tools/tasks/daily-full.ps1 -ApplyProducer -EditorLaneTerminals",
    "cursor:session": "pwsh -NoProfile -File tools/tasks/cursor-autonomous-session.ps1",
    "cursor:session:apply": "pwsh -NoProfile -File tools/tasks/cursor-autonomous-session.ps1 -ApplyProducer",
    "cursor:go": "pwsh -NoProfile -File tools/tasks/cursor-go.ps1",
    "cursor:go:editor": "pwsh -NoProfile -File tools/tasks/cursor-go.ps1 -EditorLaneTerminals",
    "cursor:resume": "pwsh -NoProfile -File tools/tasks/cursor-resume.ps1",
    "cursor:resume:editor": "pwsh -NoProfile -File tools/tasks/cursor-resume.ps1 -EditorLaneTerminals",
    "cursor:open-lanes": "pwsh -NoProfile -File tools/tasks/open-cursor-lane-windows.ps1",
    "linear:complete-from-pr": "tsx tools/linear/complete-linear-from-pr.ts",
    "linear:verify-issue-for-ship": "tsx tools/linear/verify-linear-issue-for-ship.ts",
    "linear:complete-merged-lane-prs": "pwsh -NoProfile -File tools/tasks/linear-complete-from-merged-prs.ps1",
    "qa:pr": "pwsh -NoProfile -File tools/tasks/qa-pr-handoff-local.ps1",
    "qa:lane-prs": "pwsh -NoProfile -File tools/tasks/qa-lane-pr-batch.ps1",
    "qa:agent": "pwsh -NoProfile -File tools/tasks/qa-lane-pr-batch.ps1",
    "qa:lane-prs:quick": "pwsh -NoProfile -File tools/tasks/qa-lane-pr-batch.ps1 -SkipChecksWatch",
    "qa:repair-merge": "pwsh -NoProfile -File tools/tasks/qa-merge-conflicts.ps1",
    "lane:ship": "pwsh -NoProfile -File tools/tasks/lane-ship.ps1",
    "lane:ship:lanes": "pwsh -NoProfile -File tools/tasks/lane-ship-all.ps1",
    "lane:next-cycle": "pwsh -NoProfile -File tools/tasks/lane-worktrees-reset-for-next-cycle.ps1",
    "worktrees:sync": "pwsh -NoProfile -File tools/tasks/sync-agent-worktrees.ps1",
    "linear:seed": "tsx tools/linear/seed-backlog.ts",
    "linear:wipe": "tsx tools/linear/wipe-team.ts",
    "linear:standup": "tsx tools/linear/daily-standup.ts",
    "linear:bootstrap": "tsx tools/linear/bootstrap-workspace.ts",
    "linear:dispatch": "tsx tools/linear/dispatch-tasks.ts",
    "linear:pickup": "tsx tools/linear/pickup-task.ts",
    "linear:resume-pickup": "tsx tools/linear/resume-pickup.ts",
    "linear:producer": "tsx tools/linear/producer-cycle.ts",
    "linear:close": "tsx tools/linear/close-loop.ts",
    "linear:promote": "tsx tools/linear/promote-backlog.ts",
    "linear:status": "tsx tools/linear/workspace-status.ts",
    "linear:pm-organize": "tsx tools/linear/pm-organize.ts",
    "linear:pm-assignments": "tsx tools/linear/write-pm-assignments.ts",
    "linear:label-backfill": "tsx tools/linear/backfill-role-labels.ts",
    "linear:pm-prepare": "npm run linear:bootstrap -- --apply && npm run linear:label-backfill -- --apply && npm run linear:pm-organize -- --apply && npm run linear:pm-assignments",
    "linear:kickoff-first": "tsx tools/linear/kickoff-first-issue.ts",
    "linear:kickoff-lanes": "tsx tools/linear/kickoff-lanes.ts",
    "linear:pm-feed-todo": "tsx tools/linear/pm-feed-todo.ts",
    "linear:plan-deps": "tsx tools/linear/generate-dependency-scope-plan.ts",
    "linear:apply-deps": "tsx tools/linear/apply-dependencies.ts"
  },
  "devDependencies": {
    "@linear/sdk": "^41.0.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.2"
  }
}
